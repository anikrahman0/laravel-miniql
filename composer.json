{
    "name": "yourvendor/miniql",
    "description": "A Laravel GraphQL-lite internal query engine — single endpoint, schema-driven, N+1-safe, mutation-ready.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "graphql", "api", "query-engine", "rest"],
    "authors": [
        {
            "name": "Apon Ahmed",
            "email": "apon2041@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/database": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0",
        "illuminate/routing": "^10.0|^11.0",
        "illuminate/cache": "^10.0|^11.0",
        "illuminate/console": "^10.0|^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "MiniQL\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MiniQL\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MiniQL\\MiniQLServiceProvider"
            ],
            "aliases": {
                "MiniQL": "MiniQL\\Facades\\MiniQL"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
